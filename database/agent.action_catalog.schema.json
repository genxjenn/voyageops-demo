{
  "$id": "voAgent.action_catalog",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "actionId",
    "label",
    "agentType",
    "incidentType",
    "incidentCategory",
    "active",
    "createdAt",
    "updatedAt",
    "embedding"
  ],
  "properties": {
    "actionId": { "type": "string", "minLength": 1 },
    "label": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "agentType": { "type": "string", "enum": ["guest-recovery"] },
    "incidentType": { "type": "string" },
    "incidentCategory": { "type": "string" },
    "loyaltyTier": { "type": "string" },
    "estimatedValue": { "type": "number" },
    "cost": { "type": "number" },
    "active": { "type": "boolean" },
    "embedding": {
      "type": "array",
      "minItems": 1536,
      "maxItems": 1536,
      "items": { "type": "number" }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
