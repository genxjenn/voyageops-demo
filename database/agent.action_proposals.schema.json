{
  "$id": "voAgent.action_proposals",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "proposalId",
    "agentRunId",
    "runId",
    "guestId",
    "incidentId",
    "status",
    "priority",
    "actions",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "proposalId": { "type": "string", "minLength": 1 },
    "agentRunId": { "type": "string", "minLength": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "guestId": { "type": "string", "minLength": 1 },
    "incidentId": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["proposed", "queued_for_approval", "approved", "rejected", "executed", "cancelled"]
    },
    "summary": { "type": "string" },
    "reasoning": { "type": "string" },
    "priority": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["actionId", "label"],
        "properties": {
          "actionId": { "type": "string" },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "estimatedValue": { "type": "number" }
        }
      }
    },
    "interactive": {
      "type": "object",
      "properties": {
        "operatorMessage": { "type": "string" },
        "followUpQuestions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "alternativeActions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["actionId", "label"],
            "properties": {
              "actionId": { "type": "string" },
              "label": { "type": "string" },
              "description": { "type": "string" },
              "estimatedValue": { "type": "number" }
            }
          }
        }
      }
    },
    "approval": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "approverRole": { "type": "string" }
      }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
