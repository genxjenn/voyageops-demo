{
  "$id": "voAgent.action_executions",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "executionId",
    "proposalId",
    "guestId",
    "incidentId",
    "status",
    "actions",
    "updatedAt"
  ],
  "properties": {
    "executionId": { "type": "string", "minLength": 1 },
    "proposalId": { "type": "string", "minLength": 1 },
    "guestId": { "type": "string", "minLength": 1 },
    "incidentId": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["queued_for_approval", "approved", "rejected", "executed", "failed", "cancelled"]
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["actionId", "status"],
        "properties": {
          "actionId": { "type": "string" },
          "status": { "type": "string", "enum": ["approved", "rejected", "executed", "failed"] },
          "executedAt": { "type": "string", "format": "date-time" },
          "error": { "type": "string" }
        }
      }
    },
    "approvedBy": { "type": "string" },
    "approvedAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
